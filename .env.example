# ═══════════════════════════════════════════════════════════════
#  三种配置方式按优先级排列，只需选一种填写即可
# ═══════════════════════════════════════════════════════════════

# ─── 方式一：多账号配对（最高优先级）────────────────────────────
#  格式：BASE_URL|API_KEY，多组用逗号分隔
#  适用于：合并多个 Replit 项目 / 多家供应商的额度
#
# OPENAI_ACCOUNTS=https://proxy-a.example.com/v1|sk-account-a...,https://proxy-b.example.com/v1|sk-account-b...
# ANTHROPIC_ACCOUNTS=https://proxy-a.example.com|sk-ant-account-a...,https://proxy-b.example.com|sk-ant-account-b...

# ─── 方式二：单 Base URL + 多 Key（第二优先级）──────────────────
#  适用于：同一供应商的多个账号（共用同一入口地址）
#
# OPENAI_API_KEYS=sk-account-a...,sk-account-b...,sk-account-c...
# OPENAI_BASE_URL=https://api.openai.com/v1
#
# ANTHROPIC_API_KEYS=sk-ant-account-a...,sk-ant-account-b...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── 方式三：单账号（第三优先级 / Replit AI Integration 默认）──
#  Replit 项目中添加 AI Integration 后自动注入，无需手动填写
#
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...

# ─── 代理鉴权（必填）────────────────────────────────────────────
#  客户端填入的 API Key，自定义任意字符串
PROXY_API_KEY=your-secret-key

# ─── 可选 ───────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
