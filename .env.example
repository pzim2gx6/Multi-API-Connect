# ─── OpenAI 配置 ────────────────────────────────────────────────
# 单账号（二选一）
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# 多账号（逗号分隔，优先于单账号配置）
# OPENAI_API_KEYS=sk-account1...,sk-account2...,sk-account3...
# OPENAI_BASE_URL=https://api.openai.com/v1   # 多账号共用同一 Base URL

# ─── Anthropic 配置 ──────────────────────────────────────────────
# 单账号（二选一）
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...

# 多账号（逗号分隔，优先于单账号配置）
# ANTHROPIC_API_KEYS=sk-ant-account1...,sk-ant-account2...,sk-ant-account3...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ─── 代理鉴权 ────────────────────────────────────────────────────
# 自定义字符串，填入客户端的 API Key 字段
PROXY_API_KEY=your-secret-key

# ─── 可选 ───────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info
